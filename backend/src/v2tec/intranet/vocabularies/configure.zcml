<configure xmlns="http://namespaces.zope.org/zope">

  <utility
      factory=".estados.EstadosVocabularyFactory"
      provides="zope.schema.interfaces.IVocabularyFactory"
      name="v2tec.intranet.vocabulary.estados"
      />
  <utility
      name="v2tec.intranet.vocabulary.categorias"
      component=".categorias.vocab_categorias"
      />
  <utility
      name="v2tec.intranet.vocabulary.areas"
      component=".areas.vocab_areas"
      />

</configure>
